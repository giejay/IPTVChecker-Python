# Copy this file to .env and fill in your values.
# .env is gitignored – never commit real credentials.

# Required: comma-separated playlist paths (inside container) or HTTP(S) URLs.
# Optionally prefix with a display title using TITLE@url syntax:
#   IPTV_PLAYLIST=MyProject@/data/playlist.m3u
#   IPTV_PLAYLIST=MyProject@https://example.com/playlist.m3u
# Without a title, the filename (without extension) is used.
IPTV_PLAYLIST=/data/playlist.m3u

# Optional settings
#IPTV_GROUP=Sports
#IPTV_TIMEOUT=10
#IPTV_VERBOSE=1          # 1=info, 2=debug
#IPTV_EXTENDED=10
#IPTV_SPLIT=false
#IPTV_RENAME=false
#IPTV_PROXY_LIST=/data/proxies.txt
#IPTV_TEST_GEOBLOCK=false
#IPTV_RETRIES=6
#IPTV_OUTPUT=/data/results.csv
#IPTV_CHANNEL_SEARCH=
#IPTV_SKIP_SCREENSHOTS=false

# Exclusions – applied after the inclusion filter above
# Comma-separated group names to skip entirely (case-insensitive exact match)
#IPTV_EXCLUDE_GROUP=Adults,Radio
# Regex to skip channels whose name matches, case-insensitive
#IPTV_EXCLUDE_CHANNEL=^XXX|Teleshopping

# Dry-run mode: print a grouped channel/group overview without checking any streams.
# Useful for discovering group names and channel names to build your filters.
# Set to true, then check the output, then set back to false for real runs.
#DRY_RUN=false
#IPTV_PROFILE_BITRATE=false
#IPTV_BACKOFF=linear     # none | linear | exponential
#IPTV_WORKERS=4
#IPTV_INSECURE=false

# Telegram notifications
TELEGRAM_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
TELEGRAM_NOTIFY=always   # always | on-errors

# Cron scheduling (optional)
# Leave CRON_SCHEDULE unset (or empty) to run once and exit (default behaviour).
# Set it to a standard cron expression to keep the container running and repeat
# the check on that schedule.  Examples:
#   Every 6 hours:       CRON_SCHEDULE=0 */6 * * *
#   Daily at 06:00:      CRON_SCHEDULE=0 6 * * *
#   Every 12 hours:      CRON_SCHEDULE=0 */12 * * *
#CRON_SCHEDULE=0 6 * * *

# Set to true to also run one check immediately when the container starts
# (before waiting for the first cron trigger).
#CRON_RUN_ON_START=false
